---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/Button.astro';

const serviceSchema = {
"@context":"https://schema.org",
"@type":"Service",
"name":"Diseño Web Profesional",
"provider": {"@type":"Organization","name":"CIBAI Studio","url":"https://cibai.studio"},
"description":"Diseño web profesional a medida. Webs diseñadas desde la psicología del usuario, la arquitectura de conversión y la identidad de marca.",
"url":"https://cibai.studio/servicios/diseno-web",
"areaServed":"España",
"serviceType":"Diseño Web Profesional"
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inicio","item":"https://cibai.studio"},
 {"@type":"ListItem","position": 2,"name":"Servicios","item":"https://cibai.studio/servicios"},
 {"@type":"ListItem","position": 3,"name":"Diseño Web Profesional","item":"https://cibai.studio/servicios/diseno-web"}
 ]
};

const faqSchema = {
"@context":"https://schema.org",
"@type":"FAQPage",
"mainEntity": [
 {
"@type":"Question",
"name":"¿Cuánto tiempo tarda en hacerse una web profesional?",
"acceptedAnswer": {"@type":"Answer","text":"El plazo habitual para una web corporativa es de 4 a 8 semanas, dependiendo del número de páginas y la complejidad. Proyectos más grandes como tiendas online o plataformas pueden requerir más tiempo. Siempre fijamos plazos concretos desde el primer día."}
 },
 {
"@type":"Question",
"name":"¿Incluye el diseño web el SEO técnico?",
"acceptedAnswer": {"@type":"Answer","text":"Sí. Todas las webs que desarrollamos incluyen SEO técnico básico integrado desde la estructura: velocidad de carga, Core Web Vitals, arquitectura de URLs, etiquetas semánticas y metadatos. Ofrecemos también estrategias SEO avanzadas como servicio adicional."}
 },
 {
"@type":"Question",
"name":"¿Puedo gestionar el contenido de mi web yo mismo después?",
"acceptedAnswer": {"@type":"Answer","text":"Absolutamente. Diseñamos webs con sistemas de gestión de contenido (CMS) que te permiten actualizar textos, imágenes y secciones sin conocimientos técnicos. También ofrecemos formación para que tu equipo sea autónomo desde el primer día."}
 }
 ]
};

const benefits = [
 'Diseño 100% a medida, único para tu marca',
 'Optimizada para conversión y experiencia de usuario (UX)',
 'Responsive, rápida y con Core Web Vitals optimizados',
 'Integración nativa con herramientas de analítica y CRM',
 'SEO técnico integrado desde el primer día',
];

const process = [
 { num: '01', title: 'Discovery', body: 'Analizamos tu marca, audiencia y competidores para definir la estrategia de diseño.' },
 { num: '02', title: 'Arquitectura', body: 'Definimos la estructura de la web, la jerarquía de contenidos y los flujos de usuario.' },
 { num: '03', title: 'Diseño UI', body: 'Creamos los prototipos y el diseño visual alineado con tu identidad de marca.' },
 { num: '04', title: 'Desarrollo', body: 'Maquetamos y desarrollamos la web con el stack técnico más adecuado para tu proyecto.' },
 { num: '05', title: 'Testing', body: 'Verificamos rendimiento, compatibilidad cross-browser y experiencia en todos los dispositivos.' },
 { num: '06', title: 'Lanzamiento', body: 'Publicamos la web y te entregamos los accesos y formación para gestionarla.' },
];
---

<Layout
 title="Diseño Web Profesional para Empresas"
 description="Diseño web profesional a medida. Webs diseñadas desde la psicología del usuario y la arquitectura de conversión. SEO integrado, responsive y optimizadas para conversión."
>
 <script type="application/ld+json"set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(faqSchema)} />

 <!-- Hero -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <nav class="mb-6 flex items-center gap-2 font-mono text-xs text-[rgba(255,255,255,0.25)]">
 <a href="/"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Inicio</a>
 <span>/</span>
 <a href="/servicios"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Servicios</a>
 <span>/</span>
 <span class="text-red-500">Diseño Web</span>
 </nav>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Servicio</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 Diseño web que habla por tu marca — y convierte visitas en clientes.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 Creamos webs que no solo son bonitas: están diseñadas desde la psicología del usuario, la arquitectura de conversión y la identidad de marca. Tu web es tu vendedor más eficiente: trabaja 24 horas al día, 7 días a la semana, sin vacaciones ni excusas.
 </p>
 <div class="mt-8 flex flex-wrap gap-4">
 <Button href="/contacto"variant="primary"arrow>
 Quiero mi web a medida
 </Button>
 <Button href="/servicios"variant="ghost">
 Ver todos los servicios
 </Button>
 </div>
 </div>
 </div>
 </section>

 <!-- Beneficios -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1fr]">
 <div>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Qué incluye</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Diseño web profesional, completo y orientado a resultados.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)] leading-relaxed">
 No entregamos solo un diseño bonito. Entregamos una herramienta de negocio que trabaja para ti con cada visita.
 </p>
 </div>
 <ul class="space-y-4">
 {benefits.map((b) => (
 <li class="flex items-start gap-4">
 <span class="mt-0.5 shrink-0 font-mono text-sm text-red-500">✦</span>
 <span class="text-[rgba(255,255,255,0.55)]">{b}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Proceso -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="mb-12">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Cómo trabajamos</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Del briefing a la entrega — sin sorpresas.
 </h2>
 </div>
 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
 {process.map((step) => (
 <div class="process-step space-y-3 border-t border-[rgba(255,255,255,0.18)] pt-6">
 <span class="font-mono text-xs text-red-500/60">{step.num}</span>
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{step.title}</h3>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{step.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- FAQ -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-3xl px-6">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">FAQ</p>
 <h2 class="mb-10 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Preguntas frecuentes
 </h2>
 <div class="space-y-8">
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">¿Cuánto tiempo tarda en hacerse una web profesional?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">El plazo habitual para una web corporativa es de 4 a 8 semanas, dependiendo del número de páginas y la complejidad. Proyectos más grandes como tiendas online o plataformas pueden requerir más tiempo. Siempre fijamos plazos concretos desde el primer día.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">¿Incluye el diseño web el SEO técnico?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Sí. Todas las webs que desarrollamos incluyen SEO técnico básico integrado desde la estructura: velocidad de carga, Core Web Vitals, arquitectura de URLs, etiquetas semánticas y metadatos. Ofrecemos también estrategias SEO avanzadas como servicio adicional.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">¿Puedo gestionar el contenido de mi web yo mismo después?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Absolutamente. Diseñamos webs con sistemas de gestión de contenido (CMS) que te permiten actualizar textos, imágenes y secciones sin conocimientos técnicos. También ofrecemos formación para que tu equipo sea autónomo desde el primer día.</p>
 </div>
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">¿Tienes un proyecto?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Hablemos de tu web.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuita. Cuéntanos qué necesitas y te damos una propuesta concreta sin compromiso.
 </p>
 </div>
 <Button href="/contacto"variant="primary"size="lg"arrow>
 Quiero mi web a medida
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step {
 opacity: 0;
 transform: translateY(12px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step:nth-child(1) { animation-delay: 0.10s; }
 .process-step:nth-child(2) { animation-delay: 0.15s; }
 .process-step:nth-child(3) { animation-delay: 0.20s; }
 .process-step:nth-child(4) { animation-delay: 0.25s; }
 .process-step:nth-child(5) { animation-delay: 0.30s; }
 .process-step:nth-child(6) { animation-delay: 0.35s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
