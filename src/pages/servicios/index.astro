---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';

const serviceListingSchema = {
"@context":"https://schema.org",
"@type":"Service",
"name":"Servicios Digitales para Empresas",
"provider": {
"@type":"Organization",
"name":"CIBAI Studio",
"url":"https://cibai.studio"
 },
"description":"Diseño web profesional, desarrollo de webapps y SaaS, automatizaciones con IA, gestión de redes sociales, SEO y copywriting para empresas en España.",
"url":"https://cibai.studio/servicios",
"areaServed":"España",
"hasOfferCatalog": {
"@type":"OfferCatalog",
"name":"Servicios CIBAI Studio",
"itemListElement": [
 {"@type":"Offer","itemOffered": {"@type":"Service","name":"Diseño Web Profesional","url":"https://cibai.studio/servicios/diseno-web"} },
 {"@type":"Offer","itemOffered": {"@type":"Service","name":"Webapps y Desarrollo SaaS","url":"https://cibai.studio/servicios/desarrollo-web-saas"} },
 {"@type":"Offer","itemOffered": {"@type":"Service","name":"Automatizaciones e Inteligencia Artificial","url":"https://cibai.studio/servicios/automatizacion-ia"} },
 {"@type":"Offer","itemOffered": {"@type":"Service","name":"Gestión de Redes Sociales","url":"https://cibai.studio/servicios/gestion-redes-sociales"} },
 {"@type":"Offer","itemOffered": {"@type":"Service","name":"SEO y Marketing Digital","url":"https://cibai.studio/servicios/seo-marketing-digital"} },
 {"@type":"Offer","itemOffered": {"@type":"Service","name":"Copywriting y Contenido","url":"https://cibai.studio/servicios/copywriting"} }
 ]
 }
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inicio","item":"https://cibai.studio"},
 {"@type":"ListItem","position": 2,"name":"Servicios","item":"https://cibai.studio/servicios"}
 ]
};

const services = [
 {
 num: '01',
 title: 'Diseño web que habla por tu marca — y convierte visitas en clientes.',
 category: 'Diseño Web Profesional',
 description: 'Creamos webs que no solo son bonitas: están diseñadas desde la psicología del usuario, la arquitectura de conversión y la identidad de marca. Tu web es tu vendedor más eficiente: trabaja 24 horas al día, 7 días a la semana, sin vacaciones ni excusas.',
 benefits: [
 'Diseño 100% a medida, único para tu marca',
 'Optimizada para conversión y experiencia de usuario (UX)',
 'Responsive, rápida y con Core Web Vitals optimizados',
 'Integración nativa con herramientas de analítica y CRM',
 'SEO técnico integrado desde el primer día',
 ],
 cta: 'Quiero mi web a medida',
 accent: 'cyan',
 },
 {
 num: '02',
 title: 'De la idea al producto digital — sin límites técnicos.',
 category: 'Webapps y Desarrollo SaaS',
 description: 'Desarrollamos aplicaciones web y productos SaaS escalables que resuelven problemas reales. Tanto si tienes una idea en una servilleta como si ya tienes un MVP, transformamos tu visión en un producto digital que funciona, crece y genera negocio desde el primer día.',
 benefits: [
 'Arquitecturas modernas y escalables (React, Next.js, Node, etc.)',
 'UX/UI diseñado para retención, activación y monetización',
 'Metodología ágil con entregables regulares y feedback continuo',
 'Integración con APIs de pago, autenticación, notificaciones y más',
 'De la idea al lanzamiento con acompañamiento total',
 ],
 cta: 'Construye tu producto digital',
 accent: 'magenta',
 },
 {
 num: '03',
 title: 'Automatiza lo que te roba tiempo — escala lo que te da dinero.',
 category: 'Automatizaciones e Inteligencia Artificial',
 description: 'Cada hora que tu equipo dedica a tareas repetitivas es una hora que no dedica a crecer. Implementamos automatizaciones de procesos e IA aplicada a tu negocio para reducir costes operativos, eliminar errores manuales y liberar a tu equipo para lo que realmente importa.',
 benefits: [
 'Automatización de flujos de trabajo, emails, reportes y procesos repetitivos',
 'Integración de IA en atención al cliente, ventas y marketing',
 'Reducción de tiempos operativos de hasta el 70%',
 'Soluciones personalizadas sin necesidad de conocimientos técnicos',
 'ROI medible desde el primer mes',
 ],
 cta: 'Automatiza tu negocio ahora',
 accent: 'cyan',
 },
 {
 num: '04',
 title: 'Tu marca, presente y relevante donde están tus clientes.',
 category: 'Gestión de Redes Sociales',
 description: 'Las redes sociales no son un escaparate: son el primer contacto de tu cliente con tu marca. Gestionamos tu presencia digital con estrategia, creatividad y datos, creando contenido que conecta emocionalmente y genera métricas que importan a tu negocio.',
 benefits: [
 'Estrategia de contenido personalizada por plataforma y audiencia',
 'Diseño gráfico y copywriting orientado a engagement y conversión',
 'Gestión de comunidad y atención al cliente digital',
 'Calendario editorial + producción de contenido mensual',
 'Informes mensuales con KPIs alineados a tus objetivos de negocio',
 ],
 cta: 'Lleva tus redes al siguiente nivel',
 accent: 'magenta',
 },
 {
 num: '05',
 title: 'Aparece primero cuando tu cliente busca exactamente lo que tú ofreces.',
 category: 'SEO',
 description: 'El 93% de las experiencias online comienzan con una búsqueda. ¿Estás ahí cuando tu cliente te busca? Hacemos SEO técnico, de contenidos y local para posicionar tu web de forma orgánica, sostenible y medible. No prometemos magia: prometemos método, constancia y resultados.',
 benefits: [
 'Auditoría SEO técnica, on-page y de contenidos',
 'Estrategia de keywords alineada con la intención de búsqueda real',
 'Optimización de velocidad, estructura y experiencia de usuario',
 'Link building ético y de alto impacto',
 'Informes de posicionamiento mensuales con seguimiento de KPIs',
 ],
 cta: 'Quiero aparecer en Google',
 accent: 'cyan',
 },
 {
 num: '06',
 title: 'Palabras que venden — sin sonar a vendedor.',
 category: 'Copywriting y Contenido',
 description: 'Las palabras equivocadas pueden arruinar el mejor diseño. Las palabras correctas convierten un visitante curioso en un cliente convencido. Redactamos textos basados en neuromarketing y psicología del consumidor que conectan con tu audiencia y la guían hacia la acción.',
 benefits: [
 'Copy basado en neuromarketing y psicología de la persuasión',
 'Textos optimizados para SEO y conversión simultáneamente',
 'Landing pages, emails, anuncios, webs y guiones de vídeo',
 'A/B testing para maximizar el rendimiento de cada pieza',
 'Voz de marca consistente en todos los canales y formatos',
 ],
 cta: 'Quiero textos que conviertan',
 accent: 'magenta',
 },
];
---

<Layout
 title="Servicios de Diseño Web, Desarrollo e IA"
 description="Diseño web profesional, desarrollo de webapps y SaaS, automatizaciones con IA, gestión de redes sociales, SEO y copywriting para empresas en España. CIBAI Studio, Barcelona."
>
 <script type="application/ld+json"set:html={JSON.stringify(serviceListingSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />
 <!-- Hero de sección -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Servicios</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 Lo que hacemos —<br class="hidden md:block"/> y por qué importa para tu negocio
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 Cada servicio está diseñado con un único objetivo: que tu presencia digital trabaje para ti, incluso cuando tú no estás trabajando.
 </p>
 </div>
 </div>
 </section>

 <!-- Lista de servicios -->
 <section class="bg-[#000] py-4">
 <div class="mx-auto max-w-[1400px] px-6">
 {services.map((service, i) => (
 <article
 class:list={[
 'service-item group grid grid-cols-1 gap-8 border-b border-[rgba(255,255,255,0.18)] py-16 lg:grid-cols-[200px_1fr] lg:gap-16',
 i === 0 ? 'border-t' : '',
 ]}
 >
 <!-- Left: número + categoría + CTA -->
 <div class="flex flex-row items-start justify-between gap-4 lg:flex-col lg:justify-between">
 <div>
 <span class="block font-mono text-4xl font-bold text-border/50 transition-colors duration-300 group-hover:text-red-500/25">
 {service.num}
 </span>
 <p class="mt-2 font-mono text-xs font-medium uppercase tracking-widest text-[rgba(255,255,255,0.25)]">
 {service.category}
 </p>
 </div>
 <div class="shrink-0 lg:hidden">
 <Button href="/contacto"variant="secondary"size="sm"arrow>
 {service.cta}
 </Button>
 </div>
 </div>

 <!-- Right: contenido -->
 <div class="space-y-6">
 <h2 class="font-display text-2xl font-bold leading-tight tracking-tight text-[rgba(255,255,255,0.92)] md:text-3xl">
 {service.title}
 </h2>
 <p class="leading-relaxed text-[rgba(255,255,255,0.55)]">
 {service.description}
 </p>
 <ul class="space-y-2.5">
 {service.benefits.map((b) => (
 <li class="flex items-start gap-3 text-sm text-[rgba(255,255,255,0.55)]">
 <span class:list={[
 'mt-0.5 shrink-0 font-mono text-xs',
 service.accent === 'cyan' ? 'text-red-500' : 'text-cyan-500',
 ]}>✦</span>
 {b}
 </li>
 ))}
 </ul>
 <div class="hidden lg:block pt-2">
 <Button href="/contacto"variant="secondary"arrow>
 {service.cta}
 </Button>
 </div>
 </div>
 </article>
 ))}
 </div>
 </section>

 <!-- CTA final -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">¿Tienes un proyecto?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Hablemos de lo que necesitas.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuita. Sin compromisos. Solo una conversación honesta sobre cómo podemos ayudarte a crecer.
 </p>
 </div>
 <Button href="/contacto"variant="primary"size="lg"arrow>
 Cuéntanos tu proyecto
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .service-item {
 opacity: 0;
 transform: translateY(16px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .service-item:nth-child(1) { animation-delay: 0.10s; }
 .service-item:nth-child(2) { animation-delay: 0.15s; }
 .service-item:nth-child(3) { animation-delay: 0.20s; }
 .service-item:nth-child(4) { animation-delay: 0.25s; }
 .service-item:nth-child(5) { animation-delay: 0.30s; }
 .service-item:nth-child(6) { animation-delay: 0.35s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
