---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/Button.astro';

const serviceSchema = {
"@context":"https://schema.org",
"@type":"Service",
"name":"SEO y Marketing Digital",
"provider": {"@type":"Organization","name":"CIBAI Studio","url":"https://cibai.studio"},
"description":"SEO técnico, de contenidos y local para posicionar tu web en Google. Método, constancia y resultados orgánicos sostenibles. Auditoría SEO gratuita.",
"url":"https://cibai.studio/servicios/seo",
"areaServed":"España",
"serviceType":"SEO y Marketing Digital"
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inicio","item":"https://cibai.studio"},
 {"@type":"ListItem","position": 2,"name":"Servicios","item":"https://cibai.studio/servicios"},
 {"@type":"ListItem","position": 3,"name":"SEO Profesional","item":"https://cibai.studio/servicios/seo"}
 ]
};

const faqSchema = {
"@context":"https://schema.org",
"@type":"FAQPage",
"mainEntity": [
 {
"@type":"Question",
"name":"¿Cuánto tiempo tarda el SEO en dar resultados?",
"acceptedAnswer": {"@type":"Answer","text":"El SEO orgánico requiere entre 3 y 6 meses para ver resultados sólidos en keywords competitivas. Keywords con menor competencia pueden posicionarse antes. Lo importante es que los resultados son sostenibles y no dependen de inversión publicitaria constante."}
 },
 {
"@type":"Question",
"name":"¿Cuál es la diferencia entre SEO y SEM (Google Ads)?",
"acceptedAnswer": {"@type":"Answer","text":"El SEO genera tráfico orgánico gratuito a largo plazo. El SEM genera tráfico inmediato pero requiere inversión continua. Lo ideal es una estrategia combinada: SEM para resultados inmediatos y SEO para construir visibilidad sostenible."}
 },
 {
"@type":"Question",
"name":"¿Garantizáis la posición número 1 en Google?",
"acceptedAnswer": {"@type":"Answer","text":"Nadie puede garantizar posiciones específicas en Google con honestidad. Lo que garantizamos es aplicar las mejores prácticas SEO del sector, transparencia total en el proceso y resultados de posicionamiento medibles y crecientes mes a mes."}
 }
 ]
};

const benefits = [
 'Auditoría SEO técnica, on-page y de contenidos',
 'Estrategia de keywords alineada con la intención de búsqueda real',
 'Optimización de velocidad, estructura y experiencia de usuario',
 'Link building ético y de alto impacto',
 'Informes de posicionamiento mensuales con seguimiento de KPIs',
];

const process = [
 { num: '01', title: 'Auditoría', body: 'Analizamos en profundidad el estado técnico, on-page y de autoridad de tu web para identificar las oportunidades de mejora.' },
 { num: '02', title: 'Keyword Research', body: 'Mapeamos las keywords con mayor potencial de tráfico y conversión alineadas con la intención de búsqueda de tus usuarios.' },
 { num: '03', title: 'SEO Técnico', body: 'Corregimos los problemas técnicos: velocidad, indexación, estructura de URLs, datos estructurados y Core Web Vitals.' },
 { num: '04', title: 'Contenido', body: 'Creamos y optimizamos contenido que posiciona: páginas de servicio, artículos de blog y landing pages orientadas a keywords.' },
 { num: '05', title: 'Link Building', body: 'Desarrollamos la autoridad de tu dominio con una estrategia de enlaces de calidad, ética y sostenible a largo plazo.' },
 { num: '06', title: 'Reporting', body: 'Cada mes recibes un informe con la evolución del posicionamiento, el tráfico orgánico y las acciones del siguiente periodo.' },
];
---

<Layout
 title="SEO Profesional para Empresas"
 description="SEO técnico, de contenidos y local para posicionar tu web en Google. Método, constancia y resultados orgánicos sostenibles. Auditoría SEO gratuita."
>
 <script type="application/ld+json"set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(faqSchema)} />

 <!-- Hero -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <nav class="mb-6 flex items-center gap-2 font-mono text-xs text-[rgba(255,255,255,0.25)]">
 <a href="/"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Inicio</a>
 <span>/</span>
 <a href="/servicios"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Servicios</a>
 <span>/</span>
 <span class="text-red-500">SEO</span>
 </nav>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Servicio</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 Aparece primero cuando tu cliente busca exactamente lo que tú ofreces.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 El 93% de las experiencias online comienzan con una búsqueda. ¿Estás ahí cuando tu cliente te busca? Hacemos SEO técnico, de contenidos y local para posicionar tu web de forma orgánica, sostenible y medible. No prometemos magia: prometemos método, constancia y resultados que se mantienen.
 </p>
 <div class="mt-8 flex flex-wrap gap-4">
 <Button href="/contacto"variant="primary"arrow>
 Quiero aparecer en Google
 </Button>
 <Button href="/servicios"variant="ghost">
 Ver todos los servicios
 </Button>
 </div>
 </div>
 </div>
 </section>

 <!-- Beneficios -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1fr]">
 <div>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Qué incluye</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 SEO profesional, técnico y orientado a resultados sostenibles.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)] leading-relaxed">
 No hacemos SEO de atajo. Construimos visibilidad orgánica que crece mes a mes y no desaparece cuando paras de pagar.
 </p>
 </div>
 <ul class="space-y-4">
 {benefits.map((b) => (
 <li class="flex items-start gap-4">
 <span class="mt-0.5 shrink-0 font-mono text-sm text-red-500">✦</span>
 <span class="text-[rgba(255,255,255,0.55)]">{b}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Proceso -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="mb-12">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Cómo trabajamos</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 De la auditoría al posicionamiento — con método y datos.
 </h2>
 </div>
 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
 {process.map((step) => (
 <div class="process-step space-y-3 border-t border-[rgba(255,255,255,0.18)] pt-6">
 <span class="font-mono text-xs text-red-500/60">{step.num}</span>
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{step.title}</h3>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{step.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- FAQ -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-3xl px-6">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">FAQ</p>
 <h2 class="mb-10 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Preguntas frecuentes
 </h2>
 <div class="space-y-8">
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">¿Cuánto tiempo tarda el SEO en dar resultados?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">El SEO orgánico requiere entre 3 y 6 meses para ver resultados sólidos en keywords competitivas. Keywords con menor competencia pueden posicionarse antes. Lo importante es que los resultados son sostenibles y no dependen de inversión publicitaria constante.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">¿Cuál es la diferencia entre SEO y SEM (Google Ads)?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">El SEO genera tráfico orgánico gratuito a largo plazo. El SEM genera tráfico inmediato pero requiere inversión continua. Lo ideal es una estrategia combinada: SEM para resultados inmediatos y SEO para construir visibilidad sostenible.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">¿Garantizáis la posición número 1 en Google?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Nadie puede garantizar posiciones específicas en Google con honestidad. Lo que garantizamos es aplicar las mejores prácticas SEO del sector, transparencia total en el proceso y resultados de posicionamiento medibles y crecientes mes a mes.</p>
 </div>
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">¿Tienes un proyecto?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Hablemos de tu posicionamiento.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Auditoría SEO gratuita. Analizamos tu web y te decimos exactamente qué oportunidades estás perdiendo.
 </p>
 </div>
 <Button href="/contacto"variant="primary"size="lg"arrow>
 Quiero aparecer en Google
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step {
 opacity: 0;
 transform: translateY(12px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step:nth-child(1) { animation-delay: 0.10s; }
 .process-step:nth-child(2) { animation-delay: 0.15s; }
 .process-step:nth-child(3) { animation-delay: 0.20s; }
 .process-step:nth-child(4) { animation-delay: 0.25s; }
 .process-step:nth-child(5) { animation-delay: 0.30s; }
 .process-step:nth-child(6) { animation-delay: 0.35s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
