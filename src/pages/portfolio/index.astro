---
import Layout from '../../layouts/Layout.astro';
import Button from '../../components/Button.astro';

const portfolioSchema = {
"@context":"https://schema.org",
"@type":"CollectionPage",
"name":"Portfolio — CIBAI Studio",
"url":"https://cibai.studio/portfolio",
"description":"Proyectos de diseño web, desarrollo de aplicaciones y automatización con IA. Casos de éxito de CIBAI Studio.",
"publisher": {
"@type":"Organization",
"name":"CIBAI Studio",
"url":"https://cibai.studio"
 }
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inicio","item":"https://cibai.studio"},
 {"@type":"ListItem","position": 2,"name":"Portfolio","item":"https://cibai.studio/portfolio"}
 ]
};

const projects = [
 {
 title: 'E-commerce Premium',
 category: 'Diseño Web + SEO',
 description: 'Tienda online de moda premium con diseño a medida, optimización SEO y estrategia de conversión integrada.',
 result: 'TODO: Métrica de resultado real',
 accent: 'cyan',
 tags: ['Diseño Web', 'SEO', 'E-commerce'],
 },
 {
 title: 'SaaS Dashboard',
 category: 'Webapp + Automatización',
 description: 'Plataforma de gestión empresarial con automatizaciones de procesos y dashboard analítico en tiempo real.',
 result: 'TODO: Métrica de resultado real',
 accent: 'magenta',
 tags: ['Desarrollo SaaS', 'Automatización', 'IA'],
 },
 {
 title: 'Plataforma Educativa',
 category: 'Desarrollo Full-Stack',
 description: 'LMS a medida con gestión de cursos, pagos integrados y comunidad de estudiantes.',
 result: 'TODO: Métrica de resultado real',
 accent: 'cyan',
 tags: ['Full-Stack', 'UX/UI', 'Producto'],
 },
 {
 title: 'Agencia de Marketing',
 category: 'Diseño Web + Copywriting',
 description: 'Web corporativa con copy de alto impacto, animaciones premium y sistema de lead generation optimizado.',
 result: 'TODO: Métrica de resultado real',
 accent: 'magenta',
 tags: ['Diseño Web', 'Copywriting', 'CRO'],
 },
 {
 title: 'App de Automatización',
 category: 'Automatización + IA',
 description: 'Integración de agentes de IA para automatizar procesos de atención al cliente y generación de reportes.',
 result: 'TODO: Métrica de resultado real',
 accent: 'cyan',
 tags: ['IA', 'Automatización', 'Integración'],
 },
 {
 title: 'Startup Fintech',
 category: 'Webapp + Diseño',
 description: 'Producto digital para gestión de pagos con onboarding optimizado y diseño centrado en la confianza.',
 result: 'TODO: Métrica de resultado real',
 accent: 'magenta',
 tags: ['Fintech', 'UX/UI', 'Producto'],
 },
];
---

<Layout
 title="Portfolio — Proyectos Web, Apps e IA"
 description="Descubre los proyectos de diseño web, desarrollo de aplicaciones y automatización con IA de CIBAI Studio. Casos de éxito reales con resultados medibles."
>
 <script type="application/ld+json"set:html={JSON.stringify(portfolioSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />

 <!-- Hero de sección -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Portfolio</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 Proyectos que hablan<br class="hidden md:block"/> por nosotros.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 No te contamos lo buenos que somos. Te lo demostramos. Cada proyecto es una historia de transformación: de una idea a un producto, de un producto a un negocio.
 </p>
 </div>
 </div>
 </section>

 <!-- Grid de proyectos -->
 <section class="bg-[#000] py-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
 {projects.map((project, i) => (
 <article
 class="project-card group overflow-hidden border border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] transition-all duration-300 hover:border-red-500/30 hover:shadow-lg"
 style={`animation-delay: ${0.08 + i * 0.06}s`}
 >
 <!-- Imagen placeholder -->
 <div class="aspect-[16/10] w-full bg-[#000] relative overflow-hidden">
 <div class:list={[
 'absolute inset-0',
 project.accent === 'cyan'
 ? 'bg-[radial-gradient(circle_at_30%_50%,rgba(0,240,255,0.06),transparent_70%)]'
 : 'bg-[radial-gradient(circle_at_70%_50%,rgba(255,0,153,0.06),transparent_70%)]',
 ]}></div>
 <div class="absolute inset-0 flex items-center justify-center">
 <div class="border border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] px-6 py-3 font-mono text-xs text-[rgba(255,255,255,0.25)] transition-transform duration-300 group-hover:scale-105">
 <span class:list={[
 'mr-1.5 font-mono',
 project.accent === 'cyan' ? 'text-red-500' : 'text-cyan-500',
 ]}>❯</span>
 {project.title.toLowerCase().replace(/\s+/g, '-')}
 </div>
 </div>
 </div>

 <!-- Contenido -->
 <div class="p-6 space-y-4">
 <div>
 <p class="font-mono text-xs text-[rgba(255,255,255,0.25)]">{project.category}</p>
 <h2 class="mt-1 font-display text-lg font-bold text-[rgba(255,255,255,0.92)] group-hover:text-[rgba(255,255,255,0.92)] transition-colors">
 {project.title}
 </h2>
 </div>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">
 {project.description}
 </p>
 <!-- Tags -->
 <div class="flex flex-wrap gap-2">
 {project.tags.map((tag) => (
 <span class="border border-[rgba(255,255,255,0.18)] px-3 py-1 font-mono text-[10px] uppercase tracking-wider text-[rgba(255,255,255,0.25)]">
 {tag}
 </span>
 ))}
 </div>
 </div>
 </article>
 ))}
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">¿El tuyo podría ser el siguiente?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Cuéntanos tu proyecto.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuita. Sin compromisos. Solo una conversación honesta sobre cómo podemos ayudarte a crecer.
 </p>
 </div>
 <Button href="/contacto"variant="primary"size="lg"arrow>
 Cuéntanos tu proyecto
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .project-card {
 opacity: 0;
 transform: translateY(16px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
