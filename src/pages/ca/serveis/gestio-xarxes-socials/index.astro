---
import Layout from '../../../../layouts/Layout.astro';
import Button from '../../../../components/Button.astro';

const serviceSchema = {
"@context":"https://schema.org",
"@type":"Service",
"name":"Gestió de Xarxes Socials per a Empreses",
"provider": {"@type":"Organization","name":"CIBAI Studio","url":"https://cibai.studio"},
"description":"Gestió professional de xarxes socials amb estratègia, creativitat i dades. Contingut que connecta, comunitats que compren, mètriques que importen.",
"url":"https://cibai.studio/ca/serveis/gestio-xarxes-socials",
"areaServed":"Catalunya",
"serviceType":"Gestió de Xarxes Socials"
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inici","item":"https://cibai.studio/ca"},
 {"@type":"ListItem","position": 2,"name":"Serveis","item":"https://cibai.studio/ca/serveis"},
 {"@type":"ListItem","position": 3,"name":"Gestió de Xarxes Socials","item":"https://cibai.studio/ca/serveis/gestio-xarxes-socials"}
 ]
};

const faqSchema = {
"@context":"https://schema.org",
"@type":"FAQPage",
"mainEntity": [
 {
"@type":"Question",
"name":"En quines xarxes socials treballeu?",
"acceptedAnswer": {"@type":"Answer","text":"Gestionem totes les plataformes rellevants: Instagram, LinkedIn, TikTok, Facebook, X (Twitter) i YouTube. Recomanem focalitzar-se en les plataformes on és la teva audiència."}
 },
 {
"@type":"Question",
"name":"Amb quina freqüència publiqueu contingut?",
"acceptedAnswer": {"@type":"Answer","text":"Depenent del pla, publiquem entre 3 i 7 vegades per setmana per plataforma. Sempre prioritzem qualitat sobre quantitat."}
 },
 {
"@type":"Question",
"name":"Com mesureu l'èxit de la gestió de xarxes?",
"acceptedAnswer": {"@type":"Answer","text":"Definim KPIs des de l'inici alineats amb els teus objectius: abast, engagement, clics, leads generats o vendes. Cada mes reps un informe detallat amb els resultats."}
 }
 ]
};

const benefits = [
 'Estratègia de contingut personalitzada per plataforma i audiència',
 'Disseny gràfic i copywriting orientat a engagement i conversió',
 'Gestió de comunitat i atenció al client digital',
 'Calendari editorial + producció de contingut mensual',
 'Informes mensuals amb KPIs alineats als teus objectius de negoci',
];

const process = [
 { num: '01', title: 'Auditoria', body: 'Analitzem l\'estat actual de les teves xarxes, la competència i les oportunitats de la teva audiència.' },
 { num: '02', title: 'Estratègia', body: 'Definim la veu de marca, els pilars de contingut i els objectius mesurables per plataforma.' },
 { num: '03', title: 'Calendari', body: 'Creem el calendari editorial mensual amb temàtiques, formats i freqüència de publicació.' },
 { num: '04', title: 'Producció', body: 'Produïm el contingut: disseny, copy, vídeo i adaptació a cada plataforma.' },
 { num: '05', title: 'Publicació', body: 'Gestionem la publicació, les respostes i la comunitat en temps real.' },
 { num: '06', title: 'Reporting', body: 'Analitzem els resultats mensuals i ajustem l\'estratègia per millorar contínuament.' },
];
---

<Layout
 title="Gestió de Xarxes Socials per a Empreses"
 description="Gestió professional de xarxes socials amb estratègia, creativitat i dades. Contingut que connecta, comunitats que compren, mètriques que importen."
>
 <script type="application/ld+json"set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(faqSchema)} />

 <!-- Hero -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <nav class="mb-6 flex items-center gap-2 font-mono text-xs text-[rgba(255,255,255,0.25)]">
 <a href="/ca"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Inici</a>
 <span>/</span>
 <a href="/ca/serveis"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Serveis</a>
 <span>/</span>
 <span class="text-red-500">Gestió de Xarxes Socials</span>
 </nav>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Servei</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 La teva marca, present i rellevant on són els teus clients.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 Les xarxes socials no són un aparador: són el primer contacte del teu client amb la teva marca. Gestionem la teva presència digital amb estratègia, creativitat i dades, creant contingut que connecta emocionalment, construeix comunitats que compren i genera mètriques que importen al teu negoci.
 </p>
 <div class="mt-8 flex flex-wrap gap-4">
 <Button href="/ca/contacte"variant="primary"arrow>
 Porta les teves xarxes al següent nivell
 </Button>
 <Button href="/ca/serveis"variant="ghost">
 Veure tots els serveis
 </Button>
 </div>
 </div>
 </div>
 </section>

 <!-- Beneficis -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1fr]">
 <div>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Què inclou</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Gestió professional, estratègica i orientada a resultats de negoci.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)] leading-relaxed">
 No publiquem per publicar. Cada peça de contingut té un objectiu, una audiència i un lloc en l'estratègia global de la teva marca.
 </p>
 </div>
 <ul class="space-y-4">
 {benefits.map((b) => (
 <li class="flex items-start gap-4">
 <span class="mt-0.5 shrink-0 font-mono text-sm text-red-500">✦</span>
 <span class="text-[rgba(255,255,255,0.55)]">{b}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Procés -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="mb-12">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Com treballem</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 De l'estratègia a la publicació — amb mètode i dades.
 </h2>
 </div>
 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
 {process.map((step) => (
 <div class="process-step space-y-3 border-t border-[rgba(255,255,255,0.18)] pt-6">
 <span class="font-mono text-xs text-red-500/60">{step.num}</span>
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{step.title}</h3>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{step.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- FAQ -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-3xl px-6">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">FAQ</p>
 <h2 class="mb-10 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Preguntes freqüents
 </h2>
 <div class="space-y-8">
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">En quines xarxes socials treballeu?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Gestionem totes les plataformes rellevants: Instagram, LinkedIn, TikTok, Facebook, X (Twitter) i YouTube. Recomanem focalitzar-se en les plataformes on és la teva audiència.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Amb quina freqüència publiqueu contingut?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Depenent del pla, publiquem entre 3 i 7 vegades per setmana per plataforma. Sempre prioritzem qualitat sobre quantitat.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Com mesureu l'èxit de la gestió de xarxes?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Definim KPIs des de l'inici alineats amb els teus objectius: abast, engagement, clics, leads generats o vendes. Cada mes reps un informe detallat amb els resultats.</p>
 </div>
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Tens un projecte?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Parlem de la teva presència digital.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuïta. Auditem les teves xarxes actuals i et proposem una estratègia concreta sense compromís.
 </p>
 </div>
 <Button href="/ca/contacte"variant="primary"size="lg"arrow>
 Porta les teves xarxes al següent nivell
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step {
 opacity: 0;
 transform: translateY(12px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step:nth-child(1) { animation-delay: 0.10s; }
 .process-step:nth-child(2) { animation-delay: 0.15s; }
 .process-step:nth-child(3) { animation-delay: 0.20s; }
 .process-step:nth-child(4) { animation-delay: 0.25s; }
 .process-step:nth-child(5) { animation-delay: 0.30s; }
 .process-step:nth-child(6) { animation-delay: 0.35s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
