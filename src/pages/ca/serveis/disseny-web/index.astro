---
import Layout from '../../../../layouts/Layout.astro';
import Button from '../../../../components/Button.astro';

const serviceSchema = {
"@context":"https://schema.org",
"@type":"Service",
"name":"Disseny Web Professional",
"provider": {"@type":"Organization","name":"CIBAI Studio","url":"https://cibai.studio"},
"description":"Disseny web professional a mida. Webs dissenyades des de la psicologia de l'usuari, l'arquitectura de conversió i la identitat de marca.",
"url":"https://cibai.studio/ca/serveis/disseny-web",
"areaServed":"Catalunya",
"serviceType":"Disseny Web Professional"
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inici","item":"https://cibai.studio/ca"},
 {"@type":"ListItem","position": 2,"name":"Serveis","item":"https://cibai.studio/ca/serveis"},
 {"@type":"ListItem","position": 3,"name":"Disseny Web Professional","item":"https://cibai.studio/ca/serveis/disseny-web"}
 ]
};

const faqSchema = {
"@context":"https://schema.org",
"@type":"FAQPage",
"mainEntity": [
 {
"@type":"Question",
"name":"Quant temps tarda a fer-se una web professional?",
"acceptedAnswer": {"@type":"Answer","text":"El termini habitual per a una web corporativa és de 4 a 8 setmanes, depenent del nombre de pàgines i la complexitat. Sempre fixem terminis concrets des del primer dia."}
 },
 {
"@type":"Question",
"name":"Inclou el disseny web el SEO tècnic?",
"acceptedAnswer": {"@type":"Answer","text":"Sí. Totes les webs que desenvolupem inclouen SEO tècnic bàsic integrat: velocitat de càrrega, Core Web Vitals, arquitectura d'URLs i metadades."}
 },
 {
"@type":"Question",
"name":"Puc gestionar el contingut de la meva web jo mateix després?",
"acceptedAnswer": {"@type":"Answer","text":"Absolutament. Dissenyem webs amb sistemes de gestió de contingut (CMS) que et permeten actualitzar textos i imatges sense coneixements tècnics."}
 }
 ]
};

const benefits = [
 'Disseny 100% a mida, únic per a la teva marca',
 'Optimitzada per a conversió i experiència d\'usuari (UX)',
 'Responsive, ràpida i amb Core Web Vitals optimitzats',
 'Integració nativa amb eines d\'analítica i CRM',
 'SEO tècnic integrat des del primer dia',
];

const process = [
 { num: '01', title: 'Discovery', body: 'Analitzem la teva marca, audiència i competidors per definir l\'estratègia de disseny.' },
 { num: '02', title: 'Arquitectura', body: 'Definim l\'estructura de la web, la jerarquia de continguts i els fluxos d\'usuari.' },
 { num: '03', title: 'Disseny UI', body: 'Creem els prototips i el disseny visual alineat amb la teva identitat de marca.' },
 { num: '04', title: 'Desenvolupament', body: 'Maquetam i desenvolupem la web amb l\'stack tècnic més adequat per al teu projecte.' },
 { num: '05', title: 'Testing', body: 'Verifiquem rendiment, compatibilitat cross-browser i experiència en tots els dispositius.' },
 { num: '06', title: 'Llançament', body: 'Publiquem la web i et lliurem els accessos i la formació per gestionar-la.' },
];
---

<Layout
 title="Disseny Web Professional per a Empreses"
 description="Disseny web professional a mida. Webs dissenyades des de la psicologia de l'usuari i l'arquitectura de conversió. SEO integrat, responsive i optimitzades per a conversió."
>
 <script type="application/ld+json"set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(faqSchema)} />

 <!-- Hero -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <nav class="mb-6 flex items-center gap-2 font-mono text-xs text-[rgba(255,255,255,0.25)]">
 <a href="/ca"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Inici</a>
 <span>/</span>
 <a href="/ca/serveis"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Serveis</a>
 <span>/</span>
 <span class="text-red-500">Disseny Web</span>
 </nav>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Servei</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 Disseny web que parla per la teva marca — i converteix visites en clients.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 Creem webs que no només són boniques: estan dissenyades des de la psicologia de l'usuari, l'arquitectura de conversió i la identitat de marca. La teva web és el teu venedor més eficient: treballa 24 hores al dia, 7 dies a la setmana, sense vacances ni excuses.
 </p>
 <div class="mt-8 flex flex-wrap gap-4">
 <Button href="/ca/contacte"variant="primary"arrow>
 Vull la meva web a mida
 </Button>
 <Button href="/ca/serveis"variant="ghost">
 Veure tots els serveis
 </Button>
 </div>
 </div>
 </div>
 </section>

 <!-- Beneficis -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1fr]">
 <div>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Què inclou</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Disseny web professional, complet i orientat a resultats.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)] leading-relaxed">
 No lliurem només un disseny bonic. Lliurem una eina de negoci que treballa per tu amb cada visita.
 </p>
 </div>
 <ul class="space-y-4">
 {benefits.map((b) => (
 <li class="flex items-start gap-4">
 <span class="mt-0.5 shrink-0 font-mono text-sm text-red-500">✦</span>
 <span class="text-[rgba(255,255,255,0.55)]">{b}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Procés -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="mb-12">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Com treballem</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Del briefing al lliurament — sense sorpreses.
 </h2>
 </div>
 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
 {process.map((step) => (
 <div class="process-step space-y-3 border-t border-[rgba(255,255,255,0.18)] pt-6">
 <span class="font-mono text-xs text-red-500/60">{step.num}</span>
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{step.title}</h3>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{step.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- FAQ -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-3xl px-6">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">FAQ</p>
 <h2 class="mb-10 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Preguntes freqüents
 </h2>
 <div class="space-y-8">
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Quant temps tarda a fer-se una web professional?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">El termini habitual per a una web corporativa és de 4 a 8 setmanes, depenent del nombre de pàgines i la complexitat. Sempre fixem terminis concrets des del primer dia.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Inclou el disseny web el SEO tècnic?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Sí. Totes les webs que desenvolupem inclouen SEO tècnic bàsic integrat: velocitat de càrrega, Core Web Vitals, arquitectura d'URLs i metadades.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Puc gestionar el contingut de la meva web jo mateix després?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Absolutament. Dissenyem webs amb sistemes de gestió de contingut (CMS) que et permeten actualitzar textos i imatges sense coneixements tècnics.</p>
 </div>
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Tens un projecte?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Parlem de la teva web.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuïta. Explica'ns què necessites i et donem una proposta concreta sense compromís.
 </p>
 </div>
 <Button href="/ca/contacte"variant="primary"size="lg"arrow>
 Vull la meva web a mida
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step {
 opacity: 0;
 transform: translateY(12px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step:nth-child(1) { animation-delay: 0.10s; }
 .process-step:nth-child(2) { animation-delay: 0.15s; }
 .process-step:nth-child(3) { animation-delay: 0.20s; }
 .process-step:nth-child(4) { animation-delay: 0.25s; }
 .process-step:nth-child(5) { animation-delay: 0.30s; }
 .process-step:nth-child(6) { animation-delay: 0.35s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
