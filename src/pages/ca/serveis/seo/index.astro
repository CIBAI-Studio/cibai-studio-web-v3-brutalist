---
import Layout from '../../../../layouts/Layout.astro';
import Button from '../../../../components/Button.astro';

const serviceSchema = {
"@context":"https://schema.org",
"@type":"Service",
"name":"SEO Professional per a Empreses",
"provider": {"@type":"Organization","name":"CIBAI Studio","url":"https://cibai.studio"},
"description":"SEO tècnic, de continguts i local per posicionar la teva web a Google. Mètode, constància i resultats orgànics sostenibles.",
"url":"https://cibai.studio/ca/serveis/seo",
"areaServed":"Catalunya",
"serviceType":"SEO Professional"
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inici","item":"https://cibai.studio/ca"},
 {"@type":"ListItem","position": 2,"name":"Serveis","item":"https://cibai.studio/ca/serveis"},
 {"@type":"ListItem","position": 3,"name":"SEO Professional","item":"https://cibai.studio/ca/serveis/seo"}
 ]
};

const faqSchema = {
"@context":"https://schema.org",
"@type":"FAQPage",
"mainEntity": [
 {
"@type":"Question",
"name":"Quant temps tarda el SEO a donar resultats?",
"acceptedAnswer": {"@type":"Answer","text":"El SEO orgànic requereix entre 3 i 6 mesos per veure resultats sòlids en keywords competitives. El que és important és que els resultats són sostenibles i no depenen d'inversió publicitària constant."}
 },
 {
"@type":"Question",
"name":"Quina és la diferència entre SEO i SEM (Google Ads)?",
"acceptedAnswer": {"@type":"Answer","text":"El SEO genera trànsit orgànic gratuït a llarg termini. El SEM genera trànsit immediat però requereix inversió contínua. L'ideal és una estratègia combinada."}
 },
 {
"@type":"Question",
"name":"Garantiu la posició número 1 a Google?",
"acceptedAnswer": {"@type":"Answer","text":"Ningú pot garantir posicions específiques a Google amb honestedat. El que garantim és aplicar les millors pràctiques SEO del sector i resultats de posicionament mesurables i creixents mes a mes."}
 }
 ]
};

const benefits = [
 'Auditoria SEO tècnica, on-page i de continguts',
 'Estratègia de keywords alineada amb la intenció de cerca real',
 'Optimització de velocitat, estructura i experiència d\'usuari',
 'Link building ètic i d\'alt impacte',
 'Informes de posicionament mensuals amb seguiment de KPIs',
];

const process = [
 { num: '01', title: 'Auditoria', body: 'Analitzem l\'estat tècnic i de continguts de la teva web per identificar els punts de millora amb major impacte.' },
 { num: '02', title: 'Estratègia', body: 'Definim l\'estratègia de keywords, l\'arquitectura de continguts i les prioritats d\'optimització.' },
 { num: '03', title: 'Tècnica', body: 'Resolem els problemes tècnics: velocitat, indexació, estructura d\'URLs, Core Web Vitals i dades estructurades.' },
 { num: '04', title: 'Continguts', body: 'Optimitzem les pàgines existents i creem contingut nou orientat a la intenció de cerca dels teus clients.' },
 { num: '05', title: 'Link Building', body: 'Construïm autoritat de domini amb una estratègia de link building ètica i sostenible.' },
 { num: '06', title: 'Reporting', body: 'Mesurem el posicionament, el trànsit orgànic i els KPIs de negoci mes a mes.' },
];
---

<Layout
 title="SEO Professional per a Empreses"
 description="SEO tècnic, de continguts i local per posicionar la teva web a Google. Mètode, constància i resultats orgànics sostenibles."
>
 <script type="application/ld+json"set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(faqSchema)} />

 <!-- Hero -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <nav class="mb-6 flex items-center gap-2 font-mono text-xs text-[rgba(255,255,255,0.25)]">
 <a href="/ca"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Inici</a>
 <span>/</span>
 <a href="/ca/serveis"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Serveis</a>
 <span>/</span>
 <span class="text-red-500">SEO</span>
 </nav>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Servei</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 Apareix primer quan el teu client cerca exactament el que tu ofereixes.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 El 93% de les experiències online comencen amb una cerca. Ets-hi quan el teu client et busca? Fem SEO tècnic, de continguts i local per posicionar la teva web de forma orgànica, sostenible i mesurable. No prometem màgia: prometem mètode, constància i resultats que es mantenen.
 </p>
 <div class="mt-8 flex flex-wrap gap-4">
 <Button href="/ca/contacte"variant="primary"arrow>
 Vull aparèixer a Google
 </Button>
 <Button href="/ca/serveis"variant="ghost">
 Veure tots els serveis
 </Button>
 </div>
 </div>
 </div>
 </section>

 <!-- Beneficis -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1fr]">
 <div>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Què inclou</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 SEO complet, tècnic i orientat a resultats de negoci sostenibles.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)] leading-relaxed">
 No optimitzem per algoritmes: optimitzem per les persones que cerquen el que tu ofereixes. El SEO és la inversió de màrqueting amb millor retorn a llarg termini.
 </p>
 </div>
 <ul class="space-y-4">
 {benefits.map((b) => (
 <li class="flex items-start gap-4">
 <span class="mt-0.5 shrink-0 font-mono text-sm text-red-500">✦</span>
 <span class="text-[rgba(255,255,255,0.55)]">{b}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Procés -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="mb-12">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Com treballem</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 De l'auditoria al posicionament — amb mètode i transparència.
 </h2>
 </div>
 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
 {process.map((step) => (
 <div class="process-step space-y-3 border-t border-[rgba(255,255,255,0.18)] pt-6">
 <span class="font-mono text-xs text-red-500/60">{step.num}</span>
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{step.title}</h3>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{step.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- FAQ -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-3xl px-6">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">FAQ</p>
 <h2 class="mb-10 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Preguntes freqüents
 </h2>
 <div class="space-y-8">
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Quant temps tarda el SEO a donar resultats?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">El SEO orgànic requereix entre 3 i 6 mesos per veure resultats sòlids en keywords competitives. El que és important és que els resultats són sostenibles i no depenen d'inversió publicitària constant.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Quina és la diferència entre SEO i SEM (Google Ads)?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">El SEO genera trànsit orgànic gratuït a llarg termini. El SEM genera trànsit immediat però requereix inversió contínua. L'ideal és una estratègia combinada.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Garantiu la posició número 1 a Google?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Ningú pot garantir posicions específiques a Google amb honestedat. El que garantim és aplicar les millors pràctiques SEO del sector i resultats de posicionament mesurables i creixents mes a mes.</p>
 </div>
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Tens un projecte?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Parlem del teu posicionament a Google.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuïta. Auditem la teva web i et expliquem exactament per on podem millorar el teu SEO.
 </p>
 </div>
 <Button href="/ca/contacte"variant="primary"size="lg"arrow>
 Vull aparèixer a Google
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step {
 opacity: 0;
 transform: translateY(12px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step:nth-child(1) { animation-delay: 0.10s; }
 .process-step:nth-child(2) { animation-delay: 0.15s; }
 .process-step:nth-child(3) { animation-delay: 0.20s; }
 .process-step:nth-child(4) { animation-delay: 0.25s; }
 .process-step:nth-child(5) { animation-delay: 0.30s; }
 .process-step:nth-child(6) { animation-delay: 0.35s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
