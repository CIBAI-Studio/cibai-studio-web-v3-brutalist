---
import Layout from '../../../../layouts/Layout.astro';
import Button from '../../../../components/Button.astro';

const serviceSchema = {
"@context":"https://schema.org",
"@type":"Service",
"name":"Desenvolupament de Webapps i SaaS a Mida",
"provider": {"@type":"Organization","name":"CIBAI Studio","url":"https://cibai.studio"},
"description":"Desenvolupament d'aplicacions web i productes SaaS escalables. De la idea al llançament amb acompanyament total. React, Next.js, arquitectures modernes.",
"url":"https://cibai.studio/ca/serveis/desenvolupament-web-saas",
"areaServed":"Catalunya",
"serviceType":"Desenvolupament Web i SaaS"
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inici","item":"https://cibai.studio/ca"},
 {"@type":"ListItem","position": 2,"name":"Serveis","item":"https://cibai.studio/ca/serveis"},
 {"@type":"ListItem","position": 3,"name":"Desenvolupament Web i SaaS","item":"https://cibai.studio/ca/serveis/desenvolupament-web-saas"}
 ]
};

const faqSchema = {
"@context":"https://schema.org",
"@type":"FAQPage",
"mainEntity": [
 {
"@type":"Question",
"name":"Quant costa desenvolupar una webapp o producte SaaS?",
"acceptedAnswer": {"@type":"Answer","text":"Els projectes SaaS varien molt en abast. Treballem amb pressupostos des de projectes MVP fins a plataformes enterprise. El més important és entendre l'abast real: agenda una consulta gratuïta i et donem una proposta concreta."}
 },
 {
"@type":"Question",
"name":"Quant temps tarda a desenvolupar-se una webapp?",
"acceptedAnswer": {"@type":"Answer","text":"Un MVP funcional pot estar llest en 6-10 setmanes. Treballem en sprints amb lliuraments intermedis perquè vegis progrés des de la primera setmana."}
 },
 {
"@type":"Question",
"name":"Podeu escalar l'aplicació quan la meva base d'usuaris creixi?",
"acceptedAnswer": {"@type":"Answer","text":"Sí. Dissenyem les arquitectures des de l'inici pensant en l'escalabilitat. Fem servir infraestructura cloud i patrons de disseny que permeten créixer sense refactoritzacions costoses."}
 }
 ]
};

const benefits = [
 'Arquitectures modernes i escalables (React, Next.js, Node, etc.)',
 'UX/UI dissenyat per a retenció, activació i monetització',
 'Metodologia àgil amb lliurables regulars i feedback continu',
 'Integració amb APIs de pagament, autenticació, notificacions i més',
 'De la idea al llançament amb acompanyament total',
];

const process = [
 { num: '01', title: 'Discovery', body: 'Analitzem la teva idea, el mercat i els usuaris per definir l\'abast i la viabilitat tècnica.' },
 { num: '02', title: 'Arquitectura', body: 'Dissenyem l\'arquitectura tècnica i el model de dades pensant en l\'escalabilitat des del dia 1.' },
 { num: '03', title: 'UX/UI', body: 'Creem els fluxos d\'usuari, prototips i el disseny visual orientat a retenció i activació.' },
 { num: '04', title: 'Desenvolupament', body: 'Desenvolupem en sprints amb lliurables setmanals i demo al final de cada sprint.' },
 { num: '05', title: 'Testing i QA', body: 'Testem rendiment, seguretat, compatibilitat i experiència d\'usuari exhaustivament.' },
 { num: '06', title: 'Llançament', body: 'Despleguem a producció i t\'acompanyem en el llançament amb suport post-publicació.' },
];
---

<Layout
 title="Desenvolupament de Webapps i SaaS a Mida"
 description="Desenvolupament d'aplicacions web i SaaS escalables. De la idea al llançament amb acompanyament total. React, Next.js i arquitectures modernes."
>
 <script type="application/ld+json"set:html={JSON.stringify(serviceSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(faqSchema)} />

 <!-- Hero -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <nav class="mb-6 flex items-center gap-2 font-mono text-xs text-[rgba(255,255,255,0.25)]">
 <a href="/ca"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Inici</a>
 <span>/</span>
 <a href="/ca/serveis"class="hover:text-[rgba(255,255,255,0.92)] transition-colors">Serveis</a>
 <span>/</span>
 <span class="text-red-500">Desenvolupament Web i SaaS</span>
 </nav>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Servei</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 De la idea al producte digital — sense límits tècnics.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 Desenvolupem aplicacions web i productes SaaS escalables que resolen problemes reals. Tant si tens una idea en un tovalló com si ja tens un MVP, transformem la teva visió en un producte digital que funciona, creix i genera negoci des del primer dia.
 </p>
 <div class="mt-8 flex flex-wrap gap-4">
 <Button href="/ca/contacte"variant="primary"arrow>
 Construeix el teu producte digital
 </Button>
 <Button href="/ca/serveis"variant="ghost">
 Veure tots els serveis
 </Button>
 </div>
 </div>
 </div>
 </section>

 <!-- Beneficis -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="grid grid-cols-1 gap-12 lg:grid-cols-[1fr_1fr]">
 <div>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Què inclou</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Desenvolupament professional, escalable i orientat a negoci.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)] leading-relaxed">
 No construïm només codi. Construïm productes digitals que creixen amb el teu negoci i generen valor real des del primer dia.
 </p>
 </div>
 <ul class="space-y-4">
 {benefits.map((b) => (
 <li class="flex items-start gap-4">
 <span class="mt-0.5 shrink-0 font-mono text-sm text-red-500">✦</span>
 <span class="text-[rgba(255,255,255,0.55)]">{b}</span>
 </li>
 ))}
 </ul>
 </div>
 </div>
 </section>

 <!-- Procés -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] py-20">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="mb-12">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Com treballem</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Del briefing al llançament — sense sorpreses.
 </h2>
 </div>
 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3">
 {process.map((step) => (
 <div class="process-step space-y-3 border-t border-[rgba(255,255,255,0.18)] pt-6">
 <span class="font-mono text-xs text-red-500/60">{step.num}</span>
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{step.title}</h3>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{step.body}</p>
 </div>
 ))}
 </div>
 </div>
 </section>

 <!-- FAQ -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-20">
 <div class="mx-auto max-w-3xl px-6">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">FAQ</p>
 <h2 class="mb-10 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Preguntes freqüents
 </h2>
 <div class="space-y-8">
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Quant costa desenvolupar una webapp o producte SaaS?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Els projectes SaaS varien molt en abast. Treballem amb pressupostos des de projectes MVP fins a plataformes enterprise. El més important és entendre l'abast real: agenda una consulta gratuïta i et donem una proposta concreta.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Quant temps tarda a desenvolupar-se una webapp?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Un MVP funcional pot estar llest en 6-10 setmanes. Treballem en sprints amb lliuraments intermedis perquè vegis progrés des de la primera setmana.</p>
 </div>
 <div class="border-t border-[rgba(255,255,255,0.18)] pt-6">
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">Podeu escalar l'aplicació quan la meva base d'usuaris creixi?</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">Sí. Dissenyem les arquitectures des de l'inici pensant en l'escalabilitat. Fem servir infraestructura cloud i patrons de disseny que permeten créixer sense refactoritzacions costoses.</p>
 </div>
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Tens un projecte?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Parlem del teu producte digital.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuïta. Explica'ns la teva idea i et donem una proposta concreta sense compromís.
 </p>
 </div>
 <Button href="/ca/contacte"variant="primary"size="lg"arrow>
 Construeix el teu producte digital
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step {
 opacity: 0;
 transform: translateY(12px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .process-step:nth-child(1) { animation-delay: 0.10s; }
 .process-step:nth-child(2) { animation-delay: 0.15s; }
 .process-step:nth-child(3) { animation-delay: 0.20s; }
 .process-step:nth-child(4) { animation-delay: 0.25s; }
 .process-step:nth-child(5) { animation-delay: 0.30s; }
 .process-step:nth-child(6) { animation-delay: 0.35s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
