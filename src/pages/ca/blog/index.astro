---
import Layout from '../../../layouts/Layout.astro';
import Button from '../../../components/Button.astro';

const blogSchema = {
"@context":"https://schema.org",
"@type":"Blog",
"name":"Blog CIBAI Studio",
"url":"https://cibai.studio/ca/blog",
"description":"Articles sobre disseny web, desenvolupament d'aplicacions, automatització amb IA i estratègia digital per a empreses.",
"publisher": {
"@type":"Organization",
"name":"CIBAI Studio",
"url":"https://cibai.studio",
"logo":"https://cibai.studio/logo.svg"
 }
};

const breadcrumbSchema = {
"@context":"https://schema.org",
"@type":"BreadcrumbList",
"itemListElement": [
 {"@type":"ListItem","position": 1,"name":"Inici","item":"https://cibai.studio/ca"},
 {"@type":"ListItem","position": 2,"name":"Blog","item":"https://cibai.studio/ca/blog"}
 ]
};

const articles = [
 {
 slug: 'agents-ia-per-empreses',
 title: 'Agents IA per a empreses: què són, com funcionen i per què la teva competència ja els fa servir',
 excerpt: 'La intel·ligència artificial ha deixat de ser un concepte futurista. Descobreix com els agents d\'IA estan transformant l\'operativa empresarial i què pots automatitzar avui mateix.',
 category: 'Intel·ligència Artificial',
 readTime: '8 min',
 accent: 'cyan',
 featured: true,
 },
 {
 slug: 'disseny-web-que-converteix',
 title: 'Disseny web que converteix: els 7 elements que separen una web mediocre d\'una màquina de vendes',
 excerpt: 'No tota web bonica converteix. Analitzem els principis de disseny orientat a conversió que marquen la diferència entre una presència digital que atrau i una que genera clients.',
 category: 'Disseny Web',
 readTime: '6 min',
 accent: 'magenta',
 featured: false,
 },
 {
 slug: 'seo-tecnic-per-empreses',
 title: 'SEO tècnic el 2025: la guia definitiva per posicionar la teva web quan la teva competència no sap ni què és un canonical',
 excerpt: 'El SEO tècnic és el fonament invisible de tot bon posicionament. Aquesta guia t\'explica què és, per què importa i quins errors tècnics estan sabotejant la teva visibilitat avui mateix.',
 category: 'SEO',
 readTime: '10 min',
 accent: 'cyan',
 featured: false,
 },
];

const categories = ['Tots', 'Intel·ligència Artificial', 'Disseny Web', 'SEO', 'Automatització', 'Estratègia Digital'];
---

<Layout
 title="Blog — Disseny Web, IA i Estratègia Digital"
 description="Articles sobre disseny web, desenvolupament d'aplicacions, automatització amb intel·ligència artificial i estratègia digital. Coneixement pràctic per fer créixer el teu negoci."
>
 <script type="application/ld+json"set:html={JSON.stringify(blogSchema)} />
 <script type="application/ld+json"set:html={JSON.stringify(breadcrumbSchema)} />

 <!-- Hero de secció -->
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#000] pt-24 pb-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="page-fade-in max-w-3xl">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Blog</p>
 <h1 class="font-display text-5xl font-bold leading-[1.05] tracking-[-0.03em] text-[rgba(255,255,255,0.92)] md:text-6xl">
 Coneixement que<br class="hidden md:block"/> mou negocis.
 </h1>
 <p class="mt-6 max-w-xl text-lg leading-relaxed text-[rgba(255,255,255,0.55)]">
 Publiquem el que sabem perquè creiem que compartir coneixement és la millor manera de demostrar experiència. Sense fum, sense genèrics: només estratègia aplicada.
 </p>
 </div>
 </div>
 </section>

 <!-- Article destacat -->
 {articles.filter(a => a.featured).map((article) => (
 <section class="border-b border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <p class="mb-6 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Article destacat</p>
 <a href={`/ca/blog/${article.slug}`} class="featured-article group grid grid-cols-1 gap-8 lg:grid-cols-[1fr_1.2fr] items-center">
 <div class="aspect-[16/9] overflow-hidden border border-[rgba(255,255,255,0.18)] bg-[#000] relative">
 <div class="absolute inset-0 bg-[radial-gradient(circle_at_30%_50%,rgba(0,240,255,0.08),transparent_70%)]"></div>
 <div class="absolute inset-0 flex items-center justify-center">
 <div class="border border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] px-6 py-3 font-mono text-xs text-[rgba(255,255,255,0.25)] group-hover:scale-105 transition-transform duration-300">
 <span class="text-red-500">❯</span> {article.slug}
 </div>
 </div>
 </div>
 <div class="space-y-5">
 <div class="flex items-center gap-3">
 <span class="bg-red-500/10 px-3 py-1 font-mono text-xs text-red-500">{article.category}</span>
 <span class="font-mono text-xs text-[rgba(255,255,255,0.25)]">{article.readTime} de lectura</span>
 </div>
 <h2 class="font-display text-2xl font-bold leading-tight tracking-tight text-[rgba(255,255,255,0.92)] group-hover:text-red-500/90 transition-colors md:text-3xl">
 {article.title}
 </h2>
 <p class="leading-relaxed text-[rgba(255,255,255,0.55)]">
 {article.excerpt}
 </p>
 <div class="flex items-center gap-2 font-mono text-sm text-red-500">
 Llegir article
 <span class="transition-transform duration-200 group-hover:translate-x-1">→</span>
 </div>
 </div>
 </a>
 </div>
 </section>
 ))}

 <!-- Grid d'articles -->
 <section class="bg-[#000] py-16">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="mb-10 flex items-center gap-3 overflow-x-auto pb-2">
 {categories.map((cat, i) => (
 <button class:list={[
 'shrink-0 border px-4 py-2 font-mono text-xs transition-all duration-200',
 i === 0
 ? 'border-red-500 bg-red-500/10 text-red-500'
 : 'border-[rgba(255,255,255,0.18)] text-[rgba(255,255,255,0.25)] hover:border-red-500/40 hover:text-[rgba(255,255,255,0.92)]',
 ]}>
 {cat}
 </button>
 ))}
 </div>

 <div class="grid grid-cols-1 gap-8 md:grid-cols-2 lg:grid-cols-3">
 {articles.filter(a => !a.featured).map((article, i) => (
 <a
 href={`/ca/blog/${article.slug}`}
 class="article-card group overflow-hidden border border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] transition-all duration-300 hover:border-red-500/30 hover:shadow-md"
 style={`animation-delay: ${0.10 + i * 0.08}s`}
 >
 <div class="aspect-[16/9] w-full bg-[#000] relative overflow-hidden">
 <div class:list={[
 'absolute inset-0',
 article.accent === 'cyan'
 ? 'bg-[radial-gradient(circle_at_30%_50%,rgba(0,240,255,0.06),transparent_70%)]'
 : 'bg-[radial-gradient(circle_at_70%_50%,rgba(255,0,153,0.06),transparent_70%)]',
 ]}></div>
 <div class="absolute inset-0 flex items-center justify-center">
 <div class="border border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] px-4 py-2 font-mono text-[10px] text-[rgba(255,255,255,0.25)] transition-transform duration-300 group-hover:scale-105">
 <span class:list={[article.accent === 'cyan' ? 'text-red-500' : 'text-cyan-500']}>❯</span> {article.slug}
 </div>
 </div>
 </div>
 <div class="p-6 space-y-3">
 <div class="flex items-center gap-3">
 <span class:list={[
 ' px-2.5 py-0.5 font-mono text-[10px] uppercase tracking-wider',
 article.accent === 'cyan' ? 'bg-red-500/10 text-red-500' : 'bg-red-500-secondary/10 text-cyan-500',
 ]}>{article.category}</span>
 <span class="font-mono text-xs text-[rgba(255,255,255,0.25)]">{article.readTime}</span>
 </div>
 <h2 class="font-display text-base font-bold leading-snug text-[rgba(255,255,255,0.92)] group-hover:text-red-500/90 transition-colors">
 {article.title}
 </h2>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)] line-clamp-3">
 {article.excerpt}
 </p>
 <div class="flex items-center gap-1.5 pt-1 font-mono text-xs text-red-500/70 group-hover:text-red-500 transition-colors">
 Llegir més <span class="transition-transform duration-200 group-hover:translate-x-0.5">→</span>
 </div>
 </div>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- CTA -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Tens un projecte?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Parlem del que necessites.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuïta. Sense compromisos. Només una conversa honesta sobre com podem ajudar-te a créixer.
 </p>
 </div>
 <Button href="/ca/contacte"variant="primary"size="lg"arrow>
 Explica'ns el teu projecte
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .page-fade-in {
 opacity: 0;
 transform: translateY(20px);
 animation: pageIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .featured-article, .article-card {
 opacity: 0;
 transform: translateY(16px);
 animation: pageIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .featured-article { animation-delay: 0.12s; }
 .article-card:nth-child(1) { animation-delay: 0.10s; }
 .article-card:nth-child(2) { animation-delay: 0.18s; }

 @keyframes pageIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
