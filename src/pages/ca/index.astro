---
import Layout from '../../layouts/Layout.astro';
import Hero from '../../components/Hero.astro';
import Button from '../../components/Button.astro';
import { useTranslations } from '../../i18n/utils';

const t = useTranslations('ca');

const organizationSchema = {
"@context":"https://schema.org",
"@type":"Organization",
"name":"CIBAI Studio",
"url":"https://cibai.studio",
"logo":"https://cibai.studio/brand/logo-lockup.svg",
"description":"Agència de disseny web, desenvolupament d'aplicacions i intel·ligència artificial per a empreses a Espanya.",
"foundingLocation": {
"@type":"Place",
"addressCountry":"ES"
 },
"sameAs": [
"https://www.linkedin.com/company/cibai-studio",
"https://twitter.com/cibai_studio",
"https://instagram.com/cibai.studio"
 ],
"contactPoint": {
"@type":"ContactPoint",
"contactType":"customer service",
"url":"https://cibai.studio/ca/contacte",
"availableLanguage": ["Spanish","Catalan"]
 },
"areaServed": {
"@type":"Country",
"name":"España"
 },
"serviceType": [
"Disseny web professional",
"Desenvolupament d'aplicacions web",
"Automatització amb intel·ligència artificial",
"Gestió de xarxes socials",
"SEO i màrqueting digital",
"Copywriting"
 ]
};

const services = [
 {
 num: '01',
 title: 'Disseny Web Professional',
 description: 'Webs dissenyades des de la psicologia de l\'usuari, l\'arquitectura de conversió i la identitat de marca.',
 accent: 'cyan',
 },
 {
 num: '02',
 title: 'Webapps i Desenvolupament SaaS',
 description: 'Aplicacions web escalables que resolen problemes reals i generen negoci des del primer dia.',
 accent: 'magenta',
 },
 {
 num: '03',
 title: 'Automatitzacions i IA',
 description: 'Reduïm costos operatius i eliminem tasques repetitives amb automatització i intel·ligència artificial.',
 accent: 'cyan',
 },
 {
 num: '04',
 title: 'SEO i Copywriting',
 description: 'Posicionament orgànic i textos que converteixen visitants en clients amb mètode i dades.',
 accent: 'magenta',
 },
];

const processSteps = [
 { num: '01', title: 'Descobriment', body: 'Escoltem el teu negoci, objectius i reptes.' },
 { num: '02', title: 'Estratègia', body: 'Pla amb KPIs, fites i terminis concrets.' },
 { num: '03', title: 'Creació', body: 'Sprints àgils amb lliuraments i feedback continu.' },
 { num: '04', title: 'Llançament', body: 'Deploy controlat, verificacions i posada en marxa.' },
];
---

<Layout
 title="Disseny Web, Desenvolupament i IA a Barcelona"
 description="CIBAI Studio — Agència de disseny web, desenvolupament d'aplicacions i intel·ligència artificial per a empreses a Espanya. Transformem la teva presència digital en el teu motor de creixement."
>
 <script type="application/ld+json"set:html={JSON.stringify(organizationSchema)} />

 <!-- Hero -->
 <Hero
 eyebrow={t('hero.eyebrow')}
 title={t('hero.title')}
 subtitle={t('hero.subtitle')}
 ctaLabel={t('hero.cta')}
 ctaHref="/ca/contacte"
 ctaSecLabel={t('hero.cta.sec')}
 ctaSecHref="/ca/serveis"
 tagline={t('hero.tagline')}
 lang="ca"
 />

 <!-- Serveis destacats -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="section-fade mb-16 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
 <div class="max-w-2xl">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">{t('services.eyebrow')}</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 {t('services.title')}
 </h2>
 </div>
 <Button href="/ca/serveis"variant="ghost"size="sm"arrow>
 Veure tots els serveis
 </Button>
 </div>

 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
 {services.map((service) => (
 <a href="/ca/serveis"class="service-card group border border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] p-8 transition-all duration-300 hover:border-red-500/30 hover:shadow-md">
 <div class="flex items-start justify-between">
 <span class="font-mono text-3xl font-bold text-border/40 transition-colors duration-300 group-hover:text-red-500/20">{service.num}</span>
 <span class:list={[
 'mt-1.5 h-px w-10 transition-all duration-300 group-hover:w-16',
 service.accent === 'cyan' ? 'neon-line-cyan' : 'neon-line-magenta',
 ]}></span>
 </div>
 <h3 class="mt-5 font-display text-lg font-bold text-[rgba(255,255,255,0.92)]">{service.title}</h3>
 <p class="mt-3 text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{service.description}</p>
 </a>
 ))}
 </div>
 </div>
 </section>

 <!-- Portfolio preview -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="section-fade flex flex-col items-start justify-between gap-8 md:flex-row md:items-end">
 <div class="max-w-xl">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">{t('portfolio.eyebrow')}</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 {t('portfolio.title')}
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 {t('portfolio.subtitle')}
 </p>
 </div>
 </div>

 <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
 {[
 { title: 'E-commerce Premium', category: 'Disseny Web + SEO', accent: 'cyan' },
 { title: 'SaaS Dashboard', category: 'Webapp + Automatització', accent: 'magenta' },
 { title: 'Plataforma Educativa', category: 'Desenvolupament Full-Stack', accent: 'cyan' },
 ].map((project) => (
 <div class="portfolio-card group overflow-hidden border border-[rgba(255,255,255,0.18)] bg-[#000] transition-all duration-300 hover:border-red-500/30">
 <div class="aspect-[16/10] w-full bg-[#1A1A1A] relative overflow-hidden">
 <div class:list={[
 'absolute inset-0 opacity-[0.04]',
 project.accent === 'cyan'
 ? 'bg-[radial-gradient(circle_at_30%_50%,#00F0FF,transparent_70%)]'
 : 'bg-[radial-gradient(circle_at_70%_50%,#FF0099,transparent_70%)]',
 ]}></div>
 <div class="absolute inset-0 flex items-center justify-center">
 <div class="border border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] px-6 py-3 font-mono text-xs text-[rgba(255,255,255,0.25)] transition-transform duration-300 group-hover:scale-105">
 <span class="text-red-500">&#10095;</span> {project.title.toLowerCase().replace(/\s+/g, '-')}
 </div>
 </div>
 </div>
 <div class="p-6">
 <p class="font-mono text-xs text-[rgba(255,255,255,0.25)]">{project.category}</p>
 <h3 class="mt-2 font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{project.title}</h3>
 </div>
 </div>
 ))}
 </div>

 <div class="mt-10 text-center">
 <p class="mb-6 text-[rgba(255,255,255,0.55)]">{t('portfolio.closing')}</p>
 <Button href="/ca/contacte"variant="secondary"arrow>
 {t('portfolio.cta')}
 </Button>
 </div>
 </div>
 </section>

 <!-- Sobre nosaltres preview -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="section-fade grid grid-cols-1 gap-16 lg:grid-cols-[1fr_1.2fr]">
 <div>
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">{t('about.eyebrow')}</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 {t('about.title')}
 </h2>
 <div class="mt-8">
 <Button href="/ca/sobre-nosaltres"variant="ghost"arrow>
 Coneix l'equip
 </Button>
 </div>
 </div>
 <div class="space-y-5 text-[rgba(255,255,255,0.55)]">
 <p class="text-lg leading-relaxed text-[rgba(255,255,255,0.92)]">
 Vam fundar CIBAI Studio a Barcelona amb una convicció clara: que el disseny d'alt impacte, el desenvolupament robust i el màrqueting digital intel·ligent no haurien de ser un privilegi.
 </p>
 <p class="leading-relaxed">
 Hem reunit un equip multidisciplinari de dissenyadors, desenvolupadors i experts en IA, tots amb un criteri comú: excel·lència tècnica i passió genuïna pels resultats dels nostres clients.
 </p>
 <blockquote class="border-l-2 border-red-500 pl-5">
 <p class="text-base italic leading-relaxed text-[rgba(255,255,255,0.55)]">
"No som consultors que et diuen què fer. Som l'equip que ho fa amb tu."
 </p>
 </blockquote>
 </div>
 </div>
 </div>
 </section>

 <!-- Procés -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#0D0D0D] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="section-fade mb-12 max-w-2xl">
 <p class="mb-4 font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">{t('process.eyebrow')}</p>
 <h2 class="font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 {t('process.title')}
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 {t('process.subtitle')}
 </p>
 </div>
 <div class="grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-4">
 {processSteps.map((step) => (
 <div class="process-step space-y-3 border-t border-[rgba(255,255,255,0.18)] pt-6">
 <span class="font-mono text-xs text-red-500/60">{step.num}</span>
 <h3 class="font-display text-base font-bold text-[rgba(255,255,255,0.92)]">{step.title}</h3>
 <p class="text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">{step.body}</p>
 </div>
 ))}
 </div>
 <div class="mt-12">
 <Button href="/ca/contacte"variant="secondary"arrow>
 {t('process.cta')}
 </Button>
 </div>
 </div>
 </section>

 <!-- CTA final -->
 <section class="border-t border-[rgba(255,255,255,0.18)] bg-[#000] py-24">
 <div class="mx-auto max-w-[1400px] px-6">
 <div class="flex flex-col items-start justify-between gap-8 md:flex-row md:items-center">
 <div class="max-w-xl">
 <p class="font-mono text-xs font-medium uppercase tracking-widest text-red-500/60">Tens un projecte?</p>
 <h2 class="mt-3 font-display text-3xl font-bold tracking-tight text-[rgba(255,255,255,0.92)] md:text-4xl">
 Parlem del que necessites.
 </h2>
 <p class="mt-4 text-[rgba(255,255,255,0.55)]">
 Primera consulta gratuïta. Sense compromisos. Només una conversa honesta sobre com podem ajudar-te a créixer.
 </p>
 </div>
 <Button href="/ca/contacte"variant="primary"size="lg"arrow>
 Explica'ns el teu projecte
 </Button>
 </div>
 </div>
 </section>
</Layout>

<style>
 .section-fade {
 opacity: 0;
 transform: translateY(20px);
 animation: sectionIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .service-card, .portfolio-card, .process-step {
 opacity: 0;
 transform: translateY(12px);
 animation: sectionIn 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
 }

 .service-card:nth-child(1), .portfolio-card:nth-child(1), .process-step:nth-child(1) { animation-delay: 0.10s; }
 .service-card:nth-child(2), .portfolio-card:nth-child(2), .process-step:nth-child(2) { animation-delay: 0.16s; }
 .service-card:nth-child(3), .portfolio-card:nth-child(3), .process-step:nth-child(3) { animation-delay: 0.22s; }
 .service-card:nth-child(4), .portfolio-card:nth-child(4), .process-step:nth-child(4) { animation-delay: 0.28s; }

 @keyframes sectionIn {
 to { opacity: 1; transform: translateY(0); }
 }
</style>
