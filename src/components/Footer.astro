---
import { getLangFromUrl, useTranslations, getLocalizedPath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();
---

<footer class="border-t border-[rgba(255,255,255,0.18)] bg-[#0D0D0D]">
  <div class="mx-auto max-w-[1400px] px-6 py-16">

    <!-- Top grid: brand | nav | legal -->
    <div class="grid grid-cols-1 gap-12 md:grid-cols-[2fr_1fr_1fr]">

      <!-- Brand column -->
      <div class="space-y-5">
        <div class="flex items-center gap-1 font-display text-lg font-bold tracking-tight uppercase">
          <span class="text-[rgba(255,255,255,0.92)]">CIBAI</span>
          <span class="font-mono text-red-500 text-sm">//</span>
          <span class="text-[rgba(255,255,255,0.55)]">STUDIO</span>
        </div>
        <p class="max-w-xs text-sm leading-relaxed text-[rgba(255,255,255,0.55)]">
          {t('footer.tagline')}
        </p>
        <!-- Status badge — brutalist -->
        <div class="inline-flex items-center gap-2 border border-[rgba(255,255,255,0.18)] px-3 py-1.5 font-mono text-[10px] uppercase tracking-widest text-[rgba(255,255,255,0.25)]">
          <span class="relative flex h-1.5 w-1.5">
            <span class="absolute inline-flex h-full w-full animate-ping bg-red-500 opacity-60"></span>
            <span class="relative inline-flex h-1.5 w-1.5 bg-red-500"></span>
          </span>
          {t('footer.available')}
        </div>
      </div>

      <!-- Nav column -->
      <div>
        <p class="mb-4 font-mono text-[10px] font-medium uppercase tracking-[0.2em] text-red-500/60">
          {lang === 'ca' ? "Navegació" : "Navegación"}
        </p>
        <ul class="space-y-3 text-sm">
          {[
            { label: t('nav.home'),     href: '/'              },
            { label: t('nav.services'), href: '/servicios'     },
            { label: t('nav.about'),    href: '/sobre-nosotros'},
            { label: t('nav.contact'),  href: '/contacto'      },
          ].map(({ label, href }) => (
            <li>
              <a
                href={getLocalizedPath(href, lang)}
                class="font-mono uppercase tracking-wider text-[rgba(255,255,255,0.55)] transition-colors duration-150 hover:text-[rgba(255,255,255,0.92)]"
              >
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Legal column -->
      <div>
        <p class="mb-4 font-mono text-[10px] font-medium uppercase tracking-[0.2em] text-red-500/60">Legal</p>
        <ul class="space-y-3 text-sm">
          <li>
            <a href={lang === 'ca' ? '/ca/privacitat' : '/privacidad'} class="font-mono uppercase tracking-wider text-[rgba(255,255,255,0.55)] transition-colors duration-150 hover:text-[rgba(255,255,255,0.92)]">
              {t('footer.privacy')}
            </a>
          </li>
          <li>
            <a href={lang === 'ca' ? '/ca/avis-legal' : '/aviso-legal'} class="font-mono uppercase tracking-wider text-[rgba(255,255,255,0.55)] transition-colors duration-150 hover:text-[rgba(255,255,255,0.92)]">
              {t('footer.legal')}
            </a>
          </li>
          <li>
            <a href={lang === 'ca' ? '/ca/cookies' : '/cookies'} class="font-mono uppercase tracking-wider text-[rgba(255,255,255,0.55)] transition-colors duration-150 hover:text-[rgba(255,255,255,0.92)]">
              {t('footer.cookies')}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 flex flex-col items-start justify-between gap-4 border-t border-[rgba(255,255,255,0.06)] pt-8 md:flex-row md:items-center">
      <p class="font-mono text-[10px] uppercase tracking-widest text-[rgba(255,255,255,0.10)]">
        <span class="text-red-500/40">&copy;</span> {year} CIBAI Studio. {t('footer.rights')}
      </p>
      <p class="font-mono text-[10px] uppercase tracking-widest text-[rgba(255,255,255,0.10)]">
        {t('footer.madein')} <span class="text-red-500/50">&#9632;</span> Barcelona
      </p>
    </div>
  </div>
</footer>
